{
  "manifest_version": 3,
  "name": "FOMO - AI热点搜索",
  "description": "一键搜索 AI/LLM/Agent 相关热门开源项目和论文",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "downloads",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
